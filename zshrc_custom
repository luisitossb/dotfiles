# Personal zsh customizations

# npm user prefix
export PATH="$HOME/.local/share/npm/bin:$PATH"

# Claude Code — skip permission prompts, cap at 20 turns to prevent runaway loops
claude() { command claude --dangerously-skip-permissions --max-turns 20 "$@"; }

# openclaude with local Ollama (native provider — better tool calling)
alias oc='openclaude --provider ollama --model qwen2.5-coder:7b --dangerously-skip-permissions'

# aider - reliable file editing with local Ollama (no function-calling needed)
alias ai='aider --model ollama/qwen2.5-coder:7b --no-auto-commits'

dotfiles-sync() {
    local DOTS=~/dotfiles
    local -a R
    R=(rsync -a --delete)

    cd "$DOTS" || return 1

    # Hyprland — full sync, skip the 'hypr' symlink (points to ml4w source)
    mkdir -p config/hypr
    "${R[@]}" --exclude='hypr' ~/.config/hypr/ config/hypr/

    # ml4w user settings and color theme
    mkdir -p config/ml4w/settings config/ml4w/colors
    "${R[@]}" ~/.config/ml4w/settings/ config/ml4w/settings/
    "${R[@]}" ~/.config/ml4w/colors/   config/ml4w/colors/

    # Waybar — full theme tree
    mkdir -p config/waybar
    "${R[@]}" ~/.config/waybar/ config/waybar/

    # eww dashboard
    mkdir -p config/eww
    "${R[@]}" ~/.config/eww/ config/eww/

    # Dock
    mkdir -p config/nwg-dock-hyprland
    "${R[@]}" ~/.config/nwg-dock-hyprland/ config/nwg-dock-hyprland/

    # Apps
    "${R[@]}" ~/.config/fastfetch/            config/fastfetch/
    "${R[@]}" ~/.config/kitty/                config/kitty/
    "${R[@]}" ~/.config/ohmyposh/             config/ohmyposh/
    "${R[@]}" ~/.config/rofi/                 config/rofi/
    "${R[@]}" ~/.config/btop/                 config/btop/
    "${R[@]}" ~/.config/swaync/               config/swaync/
    "${R[@]}" ~/.config/quickshell/           config/quickshell/
    "${R[@]}" ~/.config/networkmanager-dmenu/ config/networkmanager-dmenu/

    # Home files and scripts (only .sh scripts, skip installed binaries and symlinks)
    cp ~/.zshrc_custom home/
    mkdir -p home/.local/bin home/.config/systemd/user
    "${R[@]}" --exclude='*' --include='*.sh' ~/.local/bin/ home/.local/bin/
    "${R[@]}" --exclude='default.target.wants/' ~/.config/systemd/user/ home/.config/systemd/user/

    # Sunshine remote desktop config (credentials excluded)
    mkdir -p config/sunshine
    cp ~/.config/sunshine/sunshine.conf config/sunshine/

    # AI - System Tools documentation (markdown only)
    mkdir -p docs/ai-system-tools
    rsync -a --delete --include='*.md' --exclude='*' ~/'AI - System Tools'/ docs/ai-system-tools/

    git add .
    git commit -m "sync: $(date '+%Y-%m-%d %H:%M')"
    git push
    cd - >/dev/null
}
