{
  // Workspaces
  "hyprland/workspaces": {
    "on-scroll-up": "hyprctl dispatch workspace r-1",
    "on-scroll-down": "hyprctl dispatch workspace r+1",
    "on-click": "activate",
    "active-only": false,
    "all-outputs": true,
    "format": "{id}{windows}",
    "format-window-separator": "",
    "window-rewrite-default": " ¾░Żå",
    "window-rewrite": {
      "kitty": " ¾░äø",
      "discord": " ¾░Ö»",
      "zen": " ¾░ł╣",
      "dev\\.zed\\.Zed": " ¾░śÉ",
      "spotify": " ¾░ōć",
      "steam": " ¾░ōō",
      "thunar": " ¾░ēŗ",
      "vlc": " ¾░Ģ╝",
      "obsidian": " ¾▒ō¦",
      "telegram": " ¾░©Ø",
      "code|vscodium": " ¾░©×"
    },
  },
  // Taskbar
  "wlr/taskbar": {
    "format": "{icon}",
    "icon-size": 18,
    "tooltip-format": "{title}",
    "on-click": "activate",
    "on-click-middle": "close",
    "ignore-list": [
      "Alacritty",
      "kitty"
    ],
    "app_ids-mapping": {
      "firefoxdeveloperedition": "firefox-developer-edition"
    },
    "rewrite": {
      "Firefox Web Browser": "Firefox",
      "Foot Server": "Terminal"
    }
  },
  // Hyprland Window
  "hyprland/window": {
    "max-length": 60,
    "rewrite": {
      "(.*) - Brave": "$1",
      "(.*) - Chromium": "$1",
      "(.*) - Brave Search": "$1",
      "(.*) - Outlook": "$1",
      "(.*) Microsoft Teams": "$1"
    },
    "separate-outputs": true
  },
  // ML4W Welcome App
  "custom/ml4w-welcome": {
    "on-click": "qs ipc call sidebar toggle",
    "format": "luis",
    "tooltip-format": "Open Sidebar"
  },
  // Empty
  "custom/empty": {
    "format": ""
  },
  // Tools
  "custom/tools": {
    "format": "’ŚĮ",
    "tooltip-format": "Tools",
    "on-scroll-up": "true",
    "on-scroll-down": "true"
  },

  // Now Playing
  "custom/nowplaying": {
    "exec": "~/.config/ml4w/scripts/ml4w-now-playing",
    "format": "’Ćü  {text}",
    "return-type": "json",
    "interval": 1,
    "escape": true,
    "hide-empty-text": false,
    "on-click": "playerctl play-pause",
    "on-click-right": "playerctl next",
    "on-click-middle": "playerctl previous",
    "tooltip-format": "Left: Play/Pause\nRight: Next\nMiddle: Previous"
  },
  
  // Cliphist
  "custom/cliphist": {
    "format": "’ā¬",
    "on-click": "sleep 0.1 && ~/.local/bin/cliphist-rofi-img.sh",
    "on-click-right": "sleep 0.1 && ~/.local/bin/cliphist-rofi-img.sh d",
    "on-click-middle": "sleep 0.1 && ~/.config/ml4w/scripts/ml4w-cliphist w",
    "tooltip-format": "Left: Open clipboard Manager\nRight: Delete an entry\nMiddle: Clear list",
    "on-scroll-up": "true",
    "on-scroll-down": "true"
  },
  // Updates Count
  "custom/updates": {
    "format": "’å▓  {}",
    "escape": true,
    "return-type": "json",
    "exec": "~/.config/ml4w/scripts/ml4w-check-system-updates",
    "interval": 1800,
    "signal": 1,
    "hide-empty-text": true,
    "on-click": "~/.config/ml4w/settings/installupdates.sh",
    "on-click-right": "~/.config/ml4w/settings/software.sh"
  },
  // Wallpaper
  "custom/wallpaper": {
    "format": "’ĆŠ",
    "on-click": "bash -c waypaper &",
    "on-click-right": "~/.config/hypr/scripts/wallpaper-effects.sh",
    "tooltip-format": "Left: Select a wallpaper\nRight: Select wallpaper effect"
  },
  // Waybar Themes
  "custom/waybarthemes": {
    "format": "’ģü",
    "on-click": "~/.config/waybar/themeswitcher.sh",
    "tooltip-format": "Select a waybar theme"
  },
  // Settings
  "custom/settings": {
    "format": "’Ćō",
    "on-click": "sleep 0.1 && ml4w-dotfiles-settings",
    "tooltip-format": "ML4W Settings"
  },
  // Keybindings
  "custom/keybindings": {
    "format": "’ä£",
    "on-click": "~/.config/hypr/scripts/keybindings.sh",
    "tooltip": false
  },
  // Calculator
  "custom/calculator": {
    "format": "’ć¼",
    "on-click": "qalculate-gtk",
    "tooltip-format": "Open calculator"
  },
  // Rofi Application Launcher
  "custom/appmenu": {
    "format": "",
    "on-click": "~/.config/hypr/scripts/launcher.sh",
    "on-click-right": "~/.config/hypr/scripts/keybindings.sh",
    "tooltip-format": "Left: Open the application launcher\nRight: Show all keybindings"
  },
  // Rofi Application Launcher
  "custom/appmenuicon": {
    "format": "’äĄ",
    "on-click": "sleep 0.2;rofi -show drun -replace",
    "on-click-right": "~/.config/hypr/scripts/keybindings.sh",
    "tooltip-format": "Left: Open the application launcher\nRight: Show all keybindings"
  },
  // Power Menu
  "custom/exit": {
    "format": "’Ćæ",
    "on-click": "qs ipc call power toggle",
    "tooltip-format": "Open Power Menu"
  },
  // SwayNC
  "custom/notification": {
    "tooltip-format": "Left: Notifications\nRight: Do not disturb",
    "format": "{icon}",
    "format-icons": {
      "notification": "notifications_active",
      "none": "notifications",
      "dnd-notification": "notifications_active",
      "dnd-none": "notifications_paused",
      "inhibited-notification": "notification_important",
      "inhibited-none": "notification_important",
      "dnd-inhibited-notification": "notification_off",
      "dnd-inhibited-none": "notifications_off"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },
  // Hyprsunset
  "custom/hyprshade": {
    "format": "Ņō£",
    "tooltip-format": "Toggle Screen Shader",
    "on-click": "sleep 0.5; ~/.config/ml4w/scripts/ml4w-toggle-hyprsunset",
    "on-scroll-up": "true",
    "on-scroll-down": "true"
  },
  // Server/Laptop mode toggle
  "custom/mode-toggle": {
    "exec": "~/.local/bin/mode-status.sh",
    "return-type": "json",
    "interval": 60,
    "signal": 8,
    "exec-on-event": true,
    "on-click": "~/.local/bin/toggle-mode.sh",
    "on-scroll-up": "true",
    "on-scroll-down": "true"
  },
  // Hypridle inhibitor
  "custom/hypridle": {
    "format": "’ĆŻ",
    "return-type": "json",
    "escape": true,
    "exec-on-event": true,
    "interval": 60,
    "exec": "~/.config/hypr/scripts/hypridle.sh status",
    "on-click": "~/.config/hypr/scripts/hypridle.sh toggle",
    "on-scroll-up": "true",
    "on-scroll-down": "true"
  },
  // Keyboard State
  "keyboard-state": {
    "numlock": true,
    "capslock": true,
    "format": "{name} {icon}",
    "format-icons": {
      "locked": "’ĆŻ",
      "unlocked": "’é£"
    },
    "on-scroll-up": "true",
    "on-scroll-down": "true"
  },
  // System tray
  "tray": {
    "icon-size": 21,
    "spacing": 10
  },
  // Clock
  "clock": {
    "format": "{:%I:%M %p %a}",
    "on-click": "qs ipc call calendar toggle",
    "timezone": "",
    "tooltip": false
  },
  // System
  "custom/system": {
    "format": "Ņæ│",
    "tooltip": false,
    "on-scroll-up": "true",
    "on-scroll-down": "true"
  },
  // CPU
  "cpu": {
    "format": "¾░╗¤ {usage}% ",
    "on-click": "~/.config/ml4w/settings/system-monitor.sh",
    "on-scroll-up": "true",
    "on-scroll-down": "true"
  },
  // Memory
  "memory": {
    "format": "¾░Źø {}% ",
    "on-click": "~/.config/ml4w/settings/system-monitor.sh",
    "on-scroll-up": "true",
    "on-scroll-down": "true"
  },
  // Harddisc space used
  "disk": {
    "interval": 30,
    "format": "D {percentage_used}% ",
    "path": "/",
    "on-click": "~/.config/ml4w/settings/system-monitor.sh",
    "on-scroll-up": "true",
    "on-scroll-down": "true"
  },
  "hyprland/language": {
    "format": "/ K {short}",
    "on-scroll-up": "true",
    "on-scroll-down": "true"
  },
  // Group Hardware
  "group/hardware": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 300,
      "children-class": "not-memory",
      "transition-left-to-right": false,
      "click-to-reveal": true
    },
    "modules": [
      "custom/system",
      "cpu",
      "memory"
    ]
  },
  // Group Tools
  "group/tools": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 300,
      "children-class": "not-memory",
      "transition-left-to-right": false,
      "click-to-reveal": true
    },
    "modules": [
      "custom/tools",
      "custom/cliphist",
      "custom/hyprshade",
      "power-profiles-daemon"
    ]
  },
  // Group Links
  "group/links": {
    "orientation": "horizontal",
    "modules": [
      "custom/chatgpt",
      "custom/empty"
    ]
  },
  // Group Settings
  "group/settings": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 300,
      "children-class": "not-memory",
      "transition-left-to-right": true
    },
    "modules": [
      "custom/settings",
      "custom/waybarthemes",
      "custom/wallpaper"
    ]
  },
  // Network
  "network": {
    "format": "{ifname}",
    "format-wifi": "[ ’ć½ {signalStrength}% ]",
    "format-ethernet": "[ ’×¢ ]",
    "format-disconnected": "[ ŌÜĀ Disconnected ]",
    "tooltip-format": "’×¢ {ifname} via {gwaddri}",
    "tooltip-format-wifi": "’ć½  {ifname} @ {essid}\nIP: {ipaddr}\nStrength: {signalStrength}%\nFreq: {frequency}MHz\nUp: {bandwidthUpBits} Down: {bandwidthDownBits}",
    "tooltip-format-ethernet": "’×¢ {ifname}\nIP: {ipaddr}\n up: {bandwidthUpBits} down: {bandwidthDownBits}",
    "tooltip-format-disconnected": "Disconnected",
    "max-length": 50,
    "on-click": "~/.config/ml4w/settings/networkmanager.sh",
    "on-click-right": "~/.config/ml4w/scripts/nm-applet.sh toggle",
  },
  // Battery
  "battery": {
    "interval": 1,
    "states": {
      // "good": 95,
      "warning": 30,
      "critical": 15
    },
    "format": "[ {icon} {capacity}% ]",
    "format-charging": "[ ’Ś¦  {capacity}% ]",
    "format-plugged": "[ ’ć”  {capacity}% ]",
    "format-alt": "[ {icon} {time} ]",
    // "format-good": "", // An empty format will hide the module
    // "format-full": "",
    "format-icons": [
      "’ēä ",
      "’ēā ",
      "’ēé ",
      "’ēü ",
      "’ēĆ "
    ]
  },
  // Power Profiles Daemon
  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "’åģ",
      "performance": "’ā¦",
      "balanced": "’ĪŻ",
      "power-saver": "’ü¼"
    },
    "on-scroll-up": "true",
    "on-scroll-down": "true"
  },
  // Pulseaudio
  "pulseaudio": {
    // "scroll-step": 1, // %, can be a float
    "format": "[ {icon}  {volume}% ]",
    "format-bluetooth": "{volume}% {icon}’Ŗö {format_source}",
    "format-bluetooth-muted": "’Ü® {icon}’Ŗö {format_source}",
    "format-muted": "’Ü® {format_source}",
    "format-source": "{volume}% ’ä░",
    "format-source-muted": "’ä▒",
    "format-icons": {
      "headphone": "’Ćź ",
      "hands-free": "’¢É ",
      "headset": "’¢É ",
      "phone": "’éĢ ",
      "portable": "’éĢ ",
      "car": "’å╣ ",
      "default": [
        "’Ć”",
        "’Ć©",
        "’Ć©"
      ]
    },
    "on-click": "pavucontrol"
  },
  // Bluetooth
  "bluetooth": {
  "format": "’Ŗō {status}",
  "format-disabled": "",
  "format-off": "",
  "interval": 30,
  "on-click": "sleep 0.1 && ~/.config/ml4w/settings/bluetooth.sh",
  "tooltip-format-connected": "Connected devices: {num_connections} connected\n\n{device_enumerate}",
  "tooltip-format-enumerate-connected": "{device_alias}",
  "tooltip-format-enumerate-connected-battery": "{device_alias}\t| Battery life: {device_battery_percentage}%",
  "format-no-controller": ""
  },
  // Other
  "user": {
    "format": "{user}",
    "interval": 60,
    "icon": false
  },
  // backlight:
  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": [
      "ŅÄŹ",
      "ŅÅö",
      "ŅÅō",
      "ŅÅÆ",
      "ŅÅæ",
      "ŅÅÉ",
      "ŅÅÅ",
      "ŅÅÄ",
      "ŅÅŹ",
      "ŅÅī",
      "ŅÅŗ",
      "ŅÅŖ",
      "ŅÅē",
      "ŅÅł",
      "ŅÄø"
    ],
    "scroll-step": 1
  }
}
