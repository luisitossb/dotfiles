* {
    background: rgba(42, 51, 30, 0.7);
    primary: #b2d18a;
    primary-fixed: #cdeda3;
    primary-fixed-dim: #b2d18a;
    on-primary: #1f3701;
    on-primary-fixed: #102000;
    on-primary-fixed-variant: #354e15;
    primary-container: #354e15;
    on-primary-container: #cdeda3;
    secondary: #c0cbad;
    secondary-fixed: #dce7c7;
    secondary-fixed-dim: #c0cbad;
    on-secondary: #2a331e;
    on-secondary-fixed: #161e0b;
    on-secondary-fixed-variant: #404a33;
    secondary-container: #404a33;
    on-secondary-container: #dce7c7;
    tertiary: #a0d0cb;
    tertiary-fixed: #bcece7;
    tertiary-fixed-dim: #a0d0cb;
    on-tertiary: #003734;
    on-tertiary-fixed: #00201e;
    on-tertiary-fixed-variant: #1f4e4b;
    tertiary-container: #1f4e4b;
    on-tertiary-container: #bcece7;
    error: #ffb4ab;
    on-error: #690005;
    error-container: #93000a;
    on-error-container: #ffdad6;
    surface: #12140e;
    on-surface: #e2e3d8;
    on-surface-variant: #c5c8ba;
    outline: #8f9285;
    outline-variant: #44483d;
    shadow: #000000;
    scrim: #000000;
    inverse-surface: #e2e3d8;
    inverse-on-surface: #2f312a;
    inverse-primary: #4c662b;
    surface-dim: #12140e;
    surface-bright: #383a32;
    surface-container-lowest: #0d0f09;
    surface-container-low: #1a1c16;
    surface-container: #1e201a;
    surface-container-high: #282b24;
    surface-container-highest: #33362e;
