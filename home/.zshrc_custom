# Personal zsh customizations

# npm user prefix
export PATH="$HOME/.local/share/npm/bin:$PATH"

# Claude Code — skip permission prompts, cap at 20 turns to prevent runaway loops
claude() { command claude --dangerously-skip-permissions --max-turns 20 "$@"; }


dotfiles-sync() {
    local DOTS=~/"Ricing Hub"/dotfiles
    local -a R
    R=(rsync -a --delete)
    local msg="${1:-}"

    cd "$DOTS" || return 1

    # NOTE: kitty, btop, fastfetch, ohmyposh, matugen, Kvantum, qt6ct, cava,
    # nwg-look, and networkmanager-dmenu are SYMLINKED to the repo —
    # no sync needed for those. Only sync copy-deployed (machine-specific) configs.

    # KDE power management (server mode — no sleep/suspend)
    mkdir -p home/.config/systemd/logind.conf.d
    cp /etc/systemd/logind.conf.d/server-mode.conf home/.config/systemd/logind.conf.d/ 2>/dev/null || true
    cp ~/.config/powermanagementprofilesrc home/.config/ 2>/dev/null || true

    # Sunshine remote desktop config (credentials excluded)
    mkdir -p config/sunshine
    cp ~/.config/sunshine/sunshine.conf config/sunshine/

    # Home files and scripts
    cp ~/.zshrc ~/.zshrc_custom home/
    mkdir -p home/.local/bin home/.config/systemd/user
    "${R[@]}" --include='*.sh' --include='*.py' --exclude='*' ~/.local/bin/ home/.local/bin/
    "${R[@]}" --exclude='default.target.wants/' ~/.config/systemd/user/ home/.config/systemd/user/

    # MIME associations and local desktop overrides
    mkdir -p home/.config home/.local/share/applications
    cp ~/.config/mimeapps.list home/.config/
    "${R[@]}" ~/.local/share/applications/ home/.local/share/applications/

    # KDE color scheme + Konsole profile (if KDE is installed)
    if [[ -f ~/.local/share/color-schemes/LuisitoRice.colors ]]; then
        mkdir -p home/.local/share/color-schemes
        cp ~/.local/share/color-schemes/LuisitoRice.colors home/.local/share/color-schemes/
    fi
    if [[ -d ~/.local/share/konsole ]]; then
        mkdir -p home/.local/share/konsole
        "${R[@]}" ~/.local/share/konsole/ home/.local/share/konsole/
    fi

    # OpenCode config
    mkdir -p config/opencode
    cp ~/.config/opencode/opencode.jsonc config/opencode/

    # AI - System Tools documentation (markdown only)
    mkdir -p docs/ai-system-tools
    rsync -a --delete --include='*.md' --exclude='*' ~/'Ricing Hub'/'AI - System Tools'/ docs/ai-system-tools/

    git add .

    if git diff --cached --quiet; then
        echo "dotfiles-sync: nothing changed, skipping commit"
        cd - >/dev/null
        return 0
    fi

    echo "dotfiles-sync: changes staged:"
    git --no-pager diff --cached --stat

    local commit_msg
    if [[ -n "$msg" ]]; then
        commit_msg="$msg"
    else
        commit_msg="sync: $(date '+%Y-%m-%d %H:%M')"
    fi

    git commit -m "$commit_msg"
    git push
    cd - >/dev/null
}

