# Personal zsh customizations

# npm user prefix
export PATH="$HOME/.local/share/npm/bin:$PATH"

# Claude Code — skip permission prompts, cap at 20 turns to prevent runaway loops
claude() { command claude --dangerously-skip-permissions --max-turns 20 "$@"; }

# openclaude with local Ollama (native provider — better tool calling)
alias oc='openclaude --provider ollama --model qwen2.5-coder:7b --dangerously-skip-permissions'

# aider - reliable file editing with local Ollama (no function-calling needed)
alias ai='aider --model ollama/qwen2.5-coder:7b --no-auto-commits'

dotfiles-sync() {
    local DOTS=~/"Ricing Hub"/dotfiles
    local -a R
    R=(rsync -a --delete)
    local msg="${1:-}"

    cd "$DOTS" || return 1

    # NOTE: quickshell, waybar, kitty, rofi, btop, swaync, fastfetch, ohmyposh,
    # matugen, nwg-dock-hyprland, and networkmanager-dmenu are SYMLINKED to the repo —
    # no sync needed for those. Only sync copy-deployed (machine-specific) configs.

    # Hyprland — copy-deployed (Hyprland writes into it at login)
    mkdir -p config/hypr
    "${R[@]}" ~/.config/hypr/ config/hypr/

    # eww scripts still used by Quickshell dashboard (net-speed.sh, claude-usage.sh)
    mkdir -p config/eww
    "${R[@]}" ~/.config/eww/ config/eww/

    # Sunshine remote desktop config (credentials excluded)
    mkdir -p config/sunshine
    cp ~/.config/sunshine/sunshine.conf config/sunshine/

    # Home files and scripts
    cp ~/.zshrc ~/.zshrc_custom home/
    mkdir -p home/.local/bin home/.config/systemd/user
    "${R[@]}" --include='*.sh' --include='*.py' --exclude='*' ~/.local/bin/ home/.local/bin/
    "${R[@]}" --exclude='default.target.wants/' ~/.config/systemd/user/ home/.config/systemd/user/

    # OpenCode config
    mkdir -p config/opencode
    cp ~/.config/opencode/opencode.jsonc config/opencode/

    # AI - System Tools documentation (markdown only)
    mkdir -p docs/ai-system-tools
    rsync -a --delete --include='*.md' --exclude='*' ~/'Ricing Hub'/'AI - System Tools'/ docs/ai-system-tools/

    git add .

    if git diff --cached --quiet; then
        echo "dotfiles-sync: nothing changed, skipping commit"
        cd - >/dev/null
        return 0
    fi

    echo "dotfiles-sync: changes staged:"
    git diff --cached --stat

    local commit_msg
    if [[ -n "$msg" ]]; then
        commit_msg="$msg"
    else
        commit_msg="sync: $(date '+%Y-%m-%d %H:%M')"
    fi

    git commit -m "$commit_msg"
    git push
    cd - >/dev/null
}

# View the current Quickshell log (errors, warnings, debug output)
alias qs-log='cat "$(ls -t /run/user/1000/quickshell/by-id/*/log.qslog 2>/dev/null | head -1)"'
alias qs-errors='grep -E "WARN|ERROR" "$(ls -t /run/user/1000/quickshell/by-id/*/log.qslog 2>/dev/null | head -1)"'
